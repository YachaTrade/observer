# ============================================================
# GIWA Sepolia observer 배포 템플릿
# 값이 0x... placeholder인 항목은 배포 전 실제 값으로 교체할 것.
# ============================================================

# --- 인프라 ---
DATABASE_URL=postgres://user:password@localhost:5432/observer
REDIS_URL=redis://localhost:6379

# --- RPC (3개 모두 필수; 단일 노드만 있으면 같은 URL 반복) ---
MAIN_RPC_URL=https://sepolia-rpc.giwa.io
SUB_RPC_URL_1=https://sepolia-rpc.giwa.io
SUB_RPC_URL_2=https://sepolia-rpc.giwa.io

# --- 인덱싱 범위/배치 (값은 예시 — 운영 환경에 맞게 조정) ---
START_BLOCK=0
BLOCK_BATCH_SIZE=50
BLOCK_INTERVAL=100
BLOCK_OFFSET=0
DEFAULT_DELAY=1000
RPC_TIME_OUT=5000
PROVIDER_CHECK_INTERVAL=60
METRICS_REPORT_INTERVAL=60

# --- GIWA 컨트랙트 (배포된 실주소로 교체) ---
BONDING_CURVE=0x0000000000000000000000000000000000000000
# Canonical Uniswap V3 factory
DEX_FACTORY=0x0000000000000000000000000000000000000000
# GiwaRouter (dex Buy/Sell 소스)
DEX_ROUTER=0x0000000000000000000000000000000000000000
LP_MANAGER=0x0000000000000000000000000000000000000000
# Wrapped native — GIWA(OP Stack) WETH predeploy
WETH=0x4200000000000000000000000000000000000006

# --- 선택: 볼트/레지스트리 컨트랙트 (미배포 환경에서는 생략 가능) ---
BURN_VAULT=0x0000000000000000000000000000000000000000
LP_VAULT=0x0000000000000000000000000000000000000000
CREATOR_FEE_VAULT=0x0000000000000000000000000000000000000000
GIFT_VAULT=0x0000000000000000000000000000000000000000
DIVIDEND_VAULT=0x0000000000000000000000000000000000000000
VAULT_REGISTRY=0x0000000000000000000000000000000000000000

# --- 수수료 (컨트랙트 배포 파라미터와 일치시킬 것) ---
CREATE_FEE_AMOUNT=0
GRADUATE_FEE_AMOUNT=0
BONDING_CURVE_FEE_RATE=0.01
DEX_ROUTER_FEE_RATE=0.01

# --- 선택 (기본값 있음) ---
# testnet: Pyth/DefiLlama 대신 mock 가격 provider 사용
MODE=testnet
# STREAM_TIMEOUT=5000
# METRICS_PORT=8080
# PYTH_API_URL=https://hermes.pyth.network/v2/updates/price
# VANITY_ADDRESS_SUFFIX=7777
# DefiLlama 조회 체인 슬러그 (whitelist price_source_id가 가리키는 체인)
# DEFILLAMA_CHAIN_SLUG=ethereum
# PG_MAX_CONNECTIONS= / PG_MIN_CONNECTIONS= / PG_ACQUIRE_TIMEOUT= /
# PG_IDLE_TIMEOUT= / PG_MAX_LIFETIME= / PG_SSL_MODE= / PG_STATEMENT_CACHE_CAPACITY=
